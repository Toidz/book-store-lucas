extends ../layout/default.pug
block main
  - const steps = ["Khởi tạo đơn hàng", "Đóng gói đơn hàng","Đã gửi hàng cho đơn vị vận chuyển", "Đang giao hàng", "Đã giao hàng"];
  - const activeStep = steps.indexOf(order.statusName) 
  .container
    .section-11(style="padding-top: 20px;")
      .inner-wrap
        .inner-head
          .inner-title Trạng thái đơn hàng
        .inner-timeline(style="display:flex")
          each step, index in steps
            .timeline-item(class=index <= activeStep ? 'active' : '')
              .inner-cicle #{index + 1}
              .inner-name= step
        .inner-cancel(style="margin-top: 50px; text-align: center;")
          -if(order.status == "initial")
            button.cancel-btn(cancel-order=`/order-history/cancel/${order._id}`) Hủy đơn hàng
    .section-11(style="padding-top: 20px;")
      .inner-wrap
        .inner-head
          .inner-title Thông tin đơn hàng
        p Mã vận đơn: #{order.transportCode}
        p Mã đơn hàng: #{order.orderCode}
        p Tên khách hàng: #{order.fullName}
        p Số điện thoại: #{order.phone}
        p Ghi chú: #{order.note}
        p Phương thức thanh toán: #{order.methodName}
        p Trạng thái thanh toán: #{order.payStatusName}
        p Trạng thái đơn hàng: #{order.statusName}
        p Ngày đặt: #{order.createdAtFormat}

    .section-11(style="padding-top: 20px;")
      .inner-wrap
        .inner-head
          .inner-title Danh sách sản phẩm đã đặt
        .inner-tour-list
          // Tour Item
          each item in order.cart
            .inner-tour-item
              .inner-product
                .inner-image
                  a(href=`/book/detail/${item.slug}`)
                    img(
                      alt=item.name 
                      src=item.avatar
                      )
                .inner-content
                  .inner-title
                    a(href=`/book/detail/${item.slug}`) #{item.name}
              .inner-quantity
                .inner-list
                  .inner-item
                    .inner-item-label Số lượng:
                    .inner-item-price
                      span #{item.quantity}
                      span  x
                      span.inner-highlight  #{(item.priceLast).toLocaleString("vi-VN")}đ
            // End Tour Item
        .inner-list-price
          .inner-item
            .inner-item-labell Phí vận chuyển:
            .inner-item-price
              span.inner-high  #{fee.toLocaleString("vi-VN")}đ
          .inner-item
            .inner-label Tổng tiền:
            .inner-price(style= "color:red") #{order.priceTotal.toLocaleString("vi-VN")}đ