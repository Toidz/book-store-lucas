extends ../layout/default.pug
include ../mixins/product-item.pug
include ../mixins/options.pug
block main 
  // Breadcrumb
  .box-breadcrumb
    .inner-image
      img(
        alt=event.name
        src=event.avatar
        )
    .inner-content
      .container
        h1.inner-title #{event.name}
        .inner-list
          a(href="/") Trang Chủ
          a(href=`/sale/${event.slug}`) #{event.name}
   
  // End Breadcrumb
  // Section 9
  .section-9
    .container
      .inner-wrap
        .inner-left
          // Box Filter
          .box-filter
            .inner-head 
              .inner-title Bộ Lọc
              i.fa-solid.fa-filter
            .inner-body(filter-price)
              .inner-group
                .inner-label Mức giá
                select(name="" price)
                  option(value="") -- Chọn khoảng giá --
                  option(value=0) Dưới 50k
                  option(value=50) Từ 50k đến 100k
                  option(value=100) Từ 100k đến 200k
                  option(value=200) Từ 200k đến 500k
                  option(value=500) Từ 500k đến 1 triệu
                  option(value=1000) Trên 1 triệu
              .inner-group
                button(excute).inner-button Áp Dụng
              .inner-group
                button(clear).inner-button Xóa lọc
          .inner-overlay
          // End Box Filter
        .inner-right
          .inner-info
            h2.inner-title #{event.name}
          .inner-info-2
            .inner-sort
              .inner-label Sắp xếp:
              .inner-list
                button(button-asc value="asc")
                  | Giá tăng dần
                  i.fa-solid.fa-square-caret-up
                button(button-desc value="desc")
                  | Giá giảm dần
                  i.fa-solid.fa-square-caret-down
            .inner-count-record
              | Tất cả: 
              b #{totalBook} cuốn sách cần tìm
            button.inner-filter-mobile
              span.inner-title Bộ Lọc
              i.fa-solid.fa-filter
          .inner-list-tour
            - if(findBook.length >0 )
              each item in findBook
                +product-item(item)
            -else
              p(style ="font-size:21px;color:red") Không tìm thấy sản phẩm phù hợp!
            // End Product Item
          // Pagination
          .box-pagination(box-pagination)
            button(page=1).active 1
            - for(let i=2;i<=totalPage;i++)
              button(page=i) #{i}
          // End Pagination
  // End Section 9
    