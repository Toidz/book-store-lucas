extends ../layout/default.pug
include ../mixins/bread.pug
block main
  +breadcrumb(bread)
  // Section 10
  .section-10
    .container
      .inner-wrap
        .inner-left
          .box-images
            .inner-images-main
              .swiper.swiper-box-images-main
                .swiper-wrapper
                  each item in book.images
                    .swiper-slide
                      .inner-image
                        img(
                          alt=book.name
                          src=item
                          )
            .inner-images-thumb
              .swiper.swiper-box-images-thumb
                .swiper-wrapper
                  each item in book.images
                    .swiper-slide
                      .inner-image
                        img(
                          alt=book.name
                          src=item
                          )
          .box-tour-info
            .inner-title Mô tả sách
            .inner-content !{book.information}
            .inner-read-more
              button.button-outline Xem tất cả
          .box-tour-info
            .inner-title Bình luận
            .inner-comment
              - if(commentList.length > 0)
                each item in commentList
                  .inner-comment-item(style="background-color:#F8F8F8; border-radius:10px; margin-bottom:12px; padding:12px;")
                    .inner-comment-head(style="font-weight:600; margin-bottom:4px; font-size:12px") #{item.fullName}
                    .inner-comment-time(style="font-size:12px; color:#666; margin-bottom:6px;") #{item.formatCreatedAt}
                    .inner-comment-content #{item.content}
              - else
                .inner-comment-empty Chưa có bình luận nào :(( ~~~~ Hãy mua sách để bình luận ^^
            - if(id_user && canComment)
              form#book-comment-form(style="margin-top:12px;" id-book=book.id)
                textarea(
                  id="commentContent"
                  name="commentContent"
                  rows="4"
                  placeholder="Nhập bình luận của bạn..."
                  style="width:100%; padding:10px; border:1px solid #ddd; border-radius:8px; outline:none"
                )
                button.button-outline(type="submit" style="margin-top:10px;") Gửi bình luận
            - else if(id_user && !canComment)
              .inner-comment-note(style="margin-top:10px; color:#999;") #{canCommentMessage}
        .inner-right
          .box-tour-detail(book-detail)
            .inner-title-main Thông tin sách
            .inner-product
              .inner-image
                img(
                  alt="" 
                  src=book.avatar
                  )
              .inner-info
                .inner-title(style ="font-size:24px") #{book.name}
            .inner-meta
              .inner-item
                span Mã sách:
                span.inner-highlight #{book.bookCode}
              .inner-item
                span Tên tác giả:
                span.inner-highlight #{book.author}
              .inner-item
                span Nhà xuất bản:
                span.inner-highlight #{book.produce}
              .inner-item
                span Số lượng sách còn lại:
                span.inner-highlight(stock=book.numberBook) #{book.numberBook}
            .inner-quantity
              .inner-list
                .inner-item
                  .inner-item-label Số lượng mua:      
                  .inner-item-input
                    input(
                      value="1" 
                      min="1" 
                      type="number"
                      number-detail
                      )
                  .inner-item-price
                    span(number) 1
                    span x
                    span.inner-highlight(priceBook=book.priceLast?book.priceLast:book.priceBook) #{(book.priceLast?book.priceLast:book.priceBook).toLocaleString("vi-VN")}đ
            .inner-total
              .inner-id-user(id_user=id_user)
              .inner-total-label Tổng cộng:
              .inner-total-price
                span(totalPrice) #{(book.priceLast?book.priceLast:book.priceBook).toLocaleString("vi-VN")}
                span đ
            button.inner-button-add-cart(idBook = book.id) Thêm Vào Giỏ Hàng
  // End Section 10