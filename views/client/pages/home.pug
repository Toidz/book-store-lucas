extends ../layout/default.pug
include ../mixins/product-item.pug
block main 
  .section-1
    .container
      .inner-wrap
        h1.inner-title(
          data-aos-duration="800" 
          data-aos="fade-up"
          )
          | Mỗi cuốn sách là một hành trình 
          br
          | Khám phá thế giới qua từng trang sách
        p.inner-desc(
          data-aos-delay="150" 
          data-aos-duration="800" 
          data-aos="fade-up"
          )
          | Giữa thế giới đầy biến động, một cuốn sách hay không chỉ mở ra cánh cửa tri thức mà còn trở thành người bạn đồng hành lặng lẽ, giúp bạn tìm lại sự bình yên, khai phá tư duy và nuôi dưỡng tâm hồn theo cách mà không điều gì khác có thể làm được.
  // End Section 1
  if eventList && eventList.length > 0
    .event
      .container
        h2.box-title(
          data-aos-duration="800" 
          data-aos="fade-up"
        ) Sự kiện giảm giá cùng LucasBook
        .inner-wrap(
          data-aos-delay="150" 
          data-aos-duration="800" 
          data-aos="fade-up"
        )
          each item in eventList
            a(href=`/sale/${item.slug}`)
              img(src=item.avatar alt="")
  if historyBook && historyBook.length > 0
    .section-4
      .container
        h2.box-title(
          data-aos-duration="800" 
          data-aos="fade-up"
        ) Có Thể Bạn Quan Tâm

        .inner-wrap(
          data-aos-delay="150" 
          data-aos-duration="800" 
          data-aos="fade-up"
        )
          each item in historyBook
            +product-item(item)
  .section-4
    .container
      h2.box-title(
        data-aos-duration="800" 
        data-aos="fade-up"
        ) Sách Bán Chạy 
      .inner-wrap(
        data-aos-delay="150" 
        data-aos-duration="800" 
        data-aos="fade-up"
        )
        // Product Item
        each item in bestBook
          +product-item(item)
        // End Product Item
  .section-4
    .container
      h2.box-title(
        data-aos-duration="800" 
        data-aos="fade-up"
        ) Sách Mới
      .inner-wrap(
        data-aos-delay="150" 
        data-aos-duration="800" 
        data-aos="fade-up"
        )
        // Product Item
        each item in newBook
          +product-item(item)
        // End Product Item
  // End Section 4
  .section-4
    .container
      h2.box-title(
        data-aos-duration="800" 
        data-aos="fade-up"
        ) Sách Trong Nước
      .inner-wrap(
        data-aos-delay="150" 
        data-aos-duration="800" 
        data-aos="fade-up"
        )
        // Product Item
        each item in bookVn
          +product-item(item)
        // End Product Item
      .inner-button
        a.button-outline(href=`/book/sach-trong-nuoc`) Xem tất cả
  // End Section 4
  // Section 6
  .section-4
    .container
      h2.box-title(
        data-aos-duration="800" 
        data-aos="fade-up"
        ) Sách Nước Ngoài
      .inner-wrap(
        data-aos-delay="150" 
        data-aos-duration="800" 
        data-aos="fade-up"
        )
        // Product Item
        each item in bookNn
          +product-item(item)
        // End Product Item
      .inner-button
        a.button-outline(href=`/book/sach-nuoc-ngoai`) Xem tất cả
  // End Section 6

  // Section 8
  .section-8
    .container
      h2.box-title(
        data-aos-duration="800" 
        data-aos="fade-up"
        ) Bài Viết Về Sách
      .inner-wrap(
        data-aos-delay="150" 
        data-aos-duration="800" 
        data-aos="fade-up"
        )
        each item,index in newList 
          .blog-item
            a(href=`/new/${item.slug}`)
              .inner-image
                img(
                  alt=item.name
                  src=item.avatar
                  )
              .inner-content
                .inner-date #{item.createdAtFormat}
                h3.inner-title #{item.name}
  // End Section 8