extends ../layouts/default.pug
block main
  h1.box-title Tổng quan
  - if(permissions.includes("dashboard-view"))
    //- Section 1
    - if(permissions.includes("statistics-view"))
      .section-head
        .inner-head
          .inner-filter(style="display: flex; gap: 15px; align-items: center; padding: 10px; border-radius: 8px; flex-wrap: wrap;")
            .filter-buttons(style="display: flex; gap: 8px; align-items: center;")
              button.filter-btn(data-period="day" style="padding: 6px 15px; background: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Ngày
              button.filter-btn(data-period="week" style="padding: 6px 15px; background: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Tuần
              button.filter-btn(data-period="month" style="padding: 6px 15px; background: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Tháng
              button.filter-btn(data-period="year" style="padding: 6px 15px; background: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Năm
            .filter-group(style="display: flex; align-items: center; gap: 8px;")
              label(for="date-from" style="font-weight: 600; margin: 0; font-size: 14px;") Từ ngày:
              input(
                type="date"
                id="date-from"
                value=dateFromSelected
                style="padding: 5px 10px; border: 1px solid #ddd; border-radius: 4px;"
              )
            .filter-group(style="display: flex; align-items: center; gap: 8px;")
              label(for="date-to" style="font-weight: 600; margin: 0; font-size: 14px;") Đến ngày:
              input(
                type="date"
                id="date-to"
                value=dateToSelected
                style="padding: 5px 10px; border: 1px solid #ddd; border-radius: 4px;"
              )
            button#btn-filter(style="padding: 6px 15px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Áp dụng
            button#btn-export-excel(style="padding: 6px 15px; background: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 600;") Xuất Excel
      .section-1
        .inner-item
          .inner-icon
            img(src="/admin/assets/images/section-1-icon-2.svg")
          .inner-content
            .inner-title Đơn hàng
            .inner-number #{dashboard.order?dashboard.order:0}
        .inner-item
          .inner-icon
            img(src="/admin/assets/images/section-1-icon-3.svg")
          .inner-content
            .inner-title Doanh thu
            .inner-number #{dashboard.priceTotal?dashboard.priceTotal.toLocaleString("vi-VN"): 0}đ
        .inner-item
          .inner-icon
            img(src="/admin/assets/images/bookLogo.png")
          .inner-content
            .inner-title Tổng số sách
            .inner-number #{totalBook?totalBook:0}
    //- End Section 1  
    - if(permissions.includes("statistics-view"))
      .section-2
        .inner-head
          h2.inner-title Biểu đồ doanh thu
        .inner-chart(style="overflow-x:auto; margin-top: 20px;")
          canvas(id="revenue-chart" style="height:250px; width: 100%;")
    //- End Section 2
    - if(permissions.includes("statistics-view"))
      .section-2
        .inner-head
          h2.inner-title Thống kê tồn kho
        .inner-inventory 
          each item in categoryList 
            span(inventory-id=item.id) #{item.name}
        .inner-inventory-chart(style="width: 100%; overflow-x: auto;")
          .inner-c(style="min-width: 800px; height: 300px;")
            canvas#inventoryChart(style="height:270px")
      .section-top-list
        .section-2
          .inner-head
            h2.inner-title Tình trạng tồn kho
          .inner-data(style="display:none")
            span(id="data-almostOver", data-value=almostOver)
            span(id="data-soldOut", data-value=soldOut)
            span(id="data-many", data-value=many)
          .inner-inventory-status()
            canvas#inventoryStatusChart(width=400, height=400)
        .section-2
          .inner-head
            h2.inner-title Top sách bán chạy 
          .table-1
            table
              thead
                tr
                  th(style="width:2px") STT
                  th(style="width:170px") Tên sách
                  th(style="width:100px") Đã bán
                  th(style="width:170px") Doanh thu 
              tbody
                each item,index in topBook
                  tr
                    td
                      .inner-code #{index+1}
                    td
                      .inner-text #{item.name}
                    td
                      .inner-text #{item.sold}
                    td
                      .inner-text #{item.profit?item.profit.toLocaleString("vi-VN"):0}đ
    //- Section 3
    .section-3
      h2.inner-title Đơn hàng mới
      .table-1
        table
          thead
            tr
              th Mã
              th(style="width:170px") Thông tin khách
              th Danh sách sản phẩm
              th(style="width:210px") Thanh toán 
              th(style="width:200px") Trạng thái
              th.inner-text-right Ngày đặt
          tbody
            each item in orderNew
              tr
                td
                  .inner-code #{item.orderCode}
                td
                  .inner-text Họ tên: #{item.fullName}
                  .inner-text Số điện thoại: #{item.phone}
                  .inner-text Lời nhắn: #{item.note}
                td
                  each it in item.cart
                    .inner-item
                      .inner-image
                        img(src=it.avatar, alt=it.name)
                      .inner-content
                        .inner-name #{it.name}
                        .inner-quantity Số lượng: #{it.quantity} x #{it.priceLast.toLocaleString("vi-VN")}đ
                td
                  .inner-text Tổng tiền: #{item.priceTotal.toLocaleString("vi-VN")}đ
                  .inner-text PTTT: #{item.nameMethod}
                  .inner-text TTTT: #{item.nameStatusPay}
                td
                  - if(item.status == "initial")
                    .badge.badge-red Khởi tạo
                  - if(item.status == "package")
                    .badge.badge-blue Đóng gói đơn hàng
                  - if(item.status == "sent")
                    .badge.badge-violet Đã gửi hàng cho đơn vị vận chuyển
                  - if(item.status == "ship")
                    .badge.badge-orange Đang giao hàng
                  - if(item.status == "done")
                    .badge.badge-green Đã giao hàng
                  - if(item.status == "cancel")
                    .badge.badge-gray Hủy đơn
                td.inner-text-right
                  .inner-text #{item.formatTime}
                  .inner-text #{item.formatDay}
    //- End Section 3
